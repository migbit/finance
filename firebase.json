{
  "firestore": {
    "rules": "firebase/firestore.rules"
  },
  "functions": {
    "source": "firebase/functions"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "firebase/**",
      ".git/**",
      "node_modules/**",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/portfolio",
        "function": {
          "functionId": "binancePortfolio",
          "region": "europe-west1"
        }
      },
      {
        "source": "/api/coingecko/price",
        "function": {
          "functionId": "coingeckoPrice",
          "region": "europe-west1"
        }
      },
      {
        "source": "/api/coingecko/search",
        "function": {
          "functionId": "coingeckoSearch",
          "region": "europe-west1"
        }
      },
      {
        "source": "/api/cleaning-hours",
        "function": {
          "functionId": "cleaningHours",
          "region": "europe-west1"
        }
      }
    ]
  }
}
